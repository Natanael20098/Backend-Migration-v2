# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zcloud
DB_USER=zcloud
DB_PASSWORD=zcloud_secret

# Auth Service — JWT settings
# Must be at least 32 characters in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-secret-key-32c
JWT_EXPIRATION_SECONDS=86400

# Auth Service — Fernet encryption key for sensitive data fields
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Auth Service — CORS
FRONTEND_URL=http://localhost:3000

# Auth Service — Rate limiting (Flask-Limiter format)
RATE_LIMIT_DEFAULT=60 per minute
RATE_LIMIT_LOGIN=10 per minute
